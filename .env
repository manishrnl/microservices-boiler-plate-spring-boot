CONFIG_GIT_URI=https://github.com/manishrnl/microservices-boiler-plate-config-server.git
CONFIG_GIT_DEFAULT_LABEL=main

POSTGRES_DB=microservices_db
POSTGRES_USER=microservice_user
POSTGRES_PASSWORD=microservice_password
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

CONFIG_SERVER_URL=http://config-server:8888
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://discovery-client:8761/eureka/

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/microservices_db
SPRING_DATASOURCE_USERNAME=microservice_user
SPRING_DATASOURCE_PASSWORD=microservice_password
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
PAYMENT_EVENTS_TOPIC=payment-events

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.2

MAX_SESSIONS_PER_USER=5

MAIL_HOST=mailpit
MAIL_PORT=1025
ZIPKIN_ENDPOINT=http://zipkin:9411/api/v2/spans
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
